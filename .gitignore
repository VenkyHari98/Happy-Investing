# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env

# Generated data — run the scripts to regenerate locally
Source Data/Downloaded Data/
web/data/

# Daily OHLCV cache (auto-regenerated, can be large)
Scripts/strategies/.cache/

# Persistent OHLCV store (grows over time, not source code)
Scripts/strategies/.store/

# Raw session transcripts and large binary files (not needed for code)
Live Classes/**/*.txt
Live Classes/**/*.pdf

# Screener.in credentials (never commit)
screener_credentials.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
Error Log/
*.log

# Jupyter
.ipynb_checkpoints/
